# Free metadata fetches
CONTACT_EMAIL=you@example.com

# Paid scoring is never enabled implicitly. Set these only before running
# `python scripts/score_mental_health.py --execute`.
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_MODEL=MiniMax-M2.7
MINIMAX_CHAT_PATH=/text/chatcompletion_v2
MINIMAX_TIMEOUT=180
MINIMAX_RETRIES=3
